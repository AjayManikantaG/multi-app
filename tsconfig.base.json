{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@temp-workspace/core": ["libs/core/src/index.ts"],
      "@temp-workspace/ui": ["libs/ui/src/index.ts"],
      "@temp-workspace/shared": ["libs/shared/src/index.ts"],
      "@temp-workspace/entities": ["libs/entities/src/index.ts"],
      "@temp-workspace/infrastructure": ["libs/infrastructure/src/index.ts"],
      "@temp-workspace/features": ["libs/features/src/index.ts"]
    },
    "customConditions": [
      "@temp-workspace/source"
    ]
  }
}